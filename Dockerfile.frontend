# Dockerfile.frontend
FROM node:20.20-slim AS dev

# 安装pnpm
RUN npm install -g pnpm

WORKDIR /app

# 设置环境变量
ENV NODE_ENV=development \
    HOST=0.0.0.0 \
    PORT=5173

# 复制前端依赖文件
COPY apps/web/package.json apps/web/pnpm-lock.yaml ./

# 安装依赖（使用--frozen-lockfile确保lock文件一致性）
RUN pnpm install --frozen-lockfile

# 复制前端源代码
COPY apps/web/ .

# 暴露端口
EXPOSE 5173

# 开发服务器命令
CMD ["pnpm", "run", "dev", "--", "--host", "0.0.0.0"]